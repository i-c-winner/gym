APP_NAME=Gym Backend
API_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gym
REDIS_URL=redis://localhost:6379/0
HOST=0.0.0.0
PORT=8000

SESSION_COOKIE_NAME=sid
REFRESH_COOKIE_NAME=refresh_token
SESSION_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
SECURE_COOKIES=false
SAME_SITE=lax
SESSION_COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

WEBHOOK_SECRET=change-me
WEBHOOK_SIGNATURE_HEADER=X-Payment-Signature
CSRF_HEADER_NAME=X-CSRF-Token

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

LOGIN_RATE_LIMIT=5
REGISTER_RATE_LIMIT=5
RATE_LIMIT_WINDOW_SECONDS=60
RESOURCE_CACHE_TTL_SECONDS=300

DEFAULT_FROM_EMAIL=no-reply@example.com
ACCESS_CONTENT_PLACEHOLDER=Protected resource content.

TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Railway production example:
# SECURE_COOKIES=true
# SAME_SITE=none
# CORS_ORIGINS=https://your-frontend-domain.railway.app
